<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTDMapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="katachi.spring.exercise.repository.CardMapper">

	<insert id="add">
		INSERT INTO card(
			good
			,bad
			,user_id
		)
		VALUES(
			0
			,0
			,#{userId}
		)
	</insert>
	
	<update id="updateGood">
		UPDATE
			card
		SET
			good = good + 1
			
		WHERE
			id = #{id}
	</update>
	
	<update id="updateBad">
		UPDATE
			card
		SET
			bad = bad + 1
			
		WHERE
			id = #{id}
	</update>	
		
	
</mapper>