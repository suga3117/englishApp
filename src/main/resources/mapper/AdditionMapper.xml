<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTDMapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="katachi.spring.exercise.repository.AdditionMapper">

	<insert id="add">
		INSERT INTO addition(
			added_date
			,user_id
		)
		VALUES(
			SYSDATE()
			,#{userId}
		)
	</insert>
		
	
</mapper>